{
  "name": "finserv-co",
  "version": "1.0.0",
  "private": true,
  "description": "FinServ Co - Internal Operations Portal",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*",
    "tools"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/ops-portal",
    "build": "npm run build --workspace=apps/ops-portal",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest --passWithNoTests",
    "test:services": "jest --projects services/*/jest.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit --project apps/ops-portal/tsconfig.json",
    "generate:api-types": "openapi-typescript openapi/spec.yaml -o packages/api-types/src/generated.ts"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.4",
    "jest": "^29.7.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.3.2",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
